# Server Configuration
PORT=3001

# Linkup API Connection (for organization duplicate checking)
# Note: Until the linkup-api endpoint is implemented, duplicate check will be skipped
LINKUP_API_URL=http://localhost:3000

# Slack Bot Configuration
SLACK_USERS_CONNECT_BOT_TOKEN=xoxb-your-bot-token
SLACK_USERS_CONNECT_BANNED_DOMAINS=example.com,test.com

# Internal User Configuration - Phil
SLACK_PHIL_USER_ID=U123456
SLACK_PHIL_TOKEN=xoxp-phil-user-token
SLACK_PHIL_MESSAGE=here to help! You have my direct line :)

# Internal User Configuration - Sasha
SLACK_SASHA_USER_ID=U234567
SLACK_SASHA_TOKEN=xoxp-sasha-user-token
SLACK_SASHA_MESSAGE=Hi {{user}}, nice to meet you! let me know if we can help with anything

# Internal User Configuration - Boris
SLACK_BORIS_USER_ID=U345678
SLACK_BORIS_TOKEN=xoxp-boris-user-token
SLACK_BORIS_MESSAGE=

# Slack App Setup Notes:
# 1. Create a Slack App at https://api.slack.com/apps
# 2. Enable Event Subscriptions and set Request URL to: https://your-domain/slack/events
# 3. Subscribe to workspace events: member_joined_channel
# 4. Install the app to your workspace
# 5. Copy the Bot User OAuth Token (xoxb-...) to SLACK_USERS_CONNECT_BOT_TOKEN
# 6. For internal user tokens, each user needs to create a User OAuth Token (xoxp-...)
